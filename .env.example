PORT=3000

# Clave del gateway (header x-api-key)
JELOU_GATEWAY_API_KEY=tu_api_key

# Autorización Basic para api.jelou.ai/v2/databases/5372/rows (solo el token Base64, sin "Basic ")
JELOU_DATABASE_BASIC_AUTH=tu_token_basic_base64

# IDs por defecto (opcional; se pueden sobreescribir por query)
DEFAULT_COMPANY_ID=5
DEFAULT_BOT_ID=9e84df74-0dc2-4fcf-9308-cd4257f7d978
DATABASE_ID=5372

# Google Calendar (cuenta de servicio)
# Usa GOOGLE_SERVICE_ACCOUNT_KEY_PATH o GOOGLE_SERVICE_ACCOUNT_KEY (JSON en una línea)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-service-account.json
GOOGLE_CALENDAR_ID=tu-calendar-id@group.calendar.google.com

# Lista de attendees a incluir (email + idSlack)
CALENDAR_ATTENDEES_FILTER_PATH=./src/calendar/attendeesFilter.json
